        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({jsonrpc:'2.0',method:'item.get',params:{hostids:['10628'],output:['itemid','name','key_','lastvalue','units'],search:{name:'Packets on Interface'},limit:200},auth:$json.result,id:2}) }}",
