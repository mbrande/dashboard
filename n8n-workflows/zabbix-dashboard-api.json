    },
    {
      "parameters": {
        "jsCode": "const hosts = $('ZSrv Prep').first().json.hosts || [];\nconst items = $json.result || [];\n\nconst hostMap = {};\nfor (const h of hosts) {\n  hostMap[h.hostid] = {\n    hostid: h.hostid, name: h.name,\n    ip: h.interfaces?.[0]?.ip || '',\n    group: h.groups?.[0]?.name || '',\n    cpu: null, memory: null, mem_total: null, mem_available: null,\n    uptime: null, load1: null, load5: null\n  };\n}\n\nfor (const item of items) {\n  const h = hostMap[item.hostid];\n  if (!h) continue;\n  const v = parseFloat(item.lastvalue);\n  if (item.key_ === 'system.cpu.util') h.cpu = Math.round(v * 10) / 10;\n  else if (item.key_ === 'vm.memory.utilization' || item.key_ === 'vm.memory.util') h.memory = Math.round(v * 10) / 10;\n  else if (item.key_ === 'vm.memory.size[total]') h.mem_total = v;\n  else if (item.key_ === 'vm.memory.size[available]') h.mem_available = v;\n  else if (item.key_ === 'system.uptime') h.uptime = v;\n  else if (item.key_ === 'system.cpu.load[all,avg1]') h.load1 = Math.round(v * 100) / 100;\n  else if (item.key_ === 'system.cpu.load[all,avg5]') h.load5 = Math.round(v * 100) / 100;\n}\n\nreturn [{ json: { servers: Object.values(hostMap).sort((a, b) => a.name.localeCompare(b.name)) } }];"
      },
