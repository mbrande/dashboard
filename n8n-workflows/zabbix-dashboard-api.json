        "jsonBody": "={{ JSON.stringify({jsonrpc:'2.0',method:'history.get',params:{itemids:['48408','48417'],history:0,sortfield:'clock',sortorder:'ASC',time_from:Math.floor(Date.now()/1000)-10800,limit:500},auth:$json.result,id:2}) }}",
