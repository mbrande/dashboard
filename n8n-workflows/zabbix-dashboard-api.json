        1544
      ]
    },
    {
      "parameters": {
        "jsCode": "const records = $json.result || [];\n\n// Group by clock timestamp\nconst byTime = {};\nfor (const r of records) {\n  const clock = r.clock;\n  if (!byTime[clock]) byTime[clock] = { clock: parseInt(clock), in: 0, out: 0 };\n  const val = Math.round(parseFloat(r.value) * 8); // bytes/s to bits/s\n  if (r.itemid === '48408') byTime[clock].in = val;\n  else if (r.itemid === '48417') byTime[clock].out = val;\n}\n\nconst sorted = Object.values(byTime).sort((a, b) => a.clock - b.clock);\n\nconst history = sorted.map(entry => {\n  const d = new Date(entry.clock * 1000);\n  return {\n    time: d.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false }),\n    in: entry.in,\n    out: entry.out\n  };\n});\n\nreturn [{ json: { history } }];"
      },
