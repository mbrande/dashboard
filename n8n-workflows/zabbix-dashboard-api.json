    {
      "parameters": {
        "jsCode": "const hosts = $json.result || [];\nconst token = $('ZSrv Auth').item.json.result;\n\nconst body = JSON.stringify({\n  jsonrpc: '2.0',\n  method: 'item.get',\n  params: {\n    groupids: ['2','25','23','24'],\n    output: ['hostid','name','key_','lastvalue','units'],\n    filter: {\n      key_: ['system.cpu.util','vm.memory.utilization','vm.memory.util',\n             'vm.memory.size[total]','vm.memory.size[available]',\n             'system.uptime','system.cpu.load[all,avg1]','system.cpu.load[all,avg5]']\n    }\n  },\n  auth: token,\n  id: 3\n});\n\nreturn [{json: {hosts, body}}];"
      },
