      "parameters": {
        "jsCode": "const problems = $('ZP Prep').first().json.problems || [];\nconst triggers = $json.result || [];\n\nconst hostMap = {};\nfor (const t of triggers) {\n  if (t.hosts?.[0]) hostMap[t.triggerid] = t.hosts[0].name;\n}\n\nconst sevLabels = ['N/A','Info','Warning','Average','High','Disaster'];\nconst result = problems.map(p => ({\n  name: p.name,\n  severity: sevLabels[parseInt(p.severity)] || 'Unknown',\n  severity_num: parseInt(p.severity),\n  host: hostMap[p.objectid] || 'Unknown',\n  time: new Date(parseInt(p.clock) * 1000).toISOString(),\n  acknowledged: p.acknowledged === '1'\n}));\n\nreturn [{ json: { problems: result } }];"
