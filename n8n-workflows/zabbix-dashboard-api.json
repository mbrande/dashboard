      "id": "zri-items",
      "name": "ZRI Get Items",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        448,
        1232
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $json.result || [];\n\n// Group by interface name extracted from key\nconst ifaces = {};\nfor (const item of items) {\n  const match = item.key_.match(/\\[(.+?)\\]/);\n  if (!match) continue;\n  const ifName = match[1];\n  if (!ifaces[ifName]) ifaces[ifName] = { name: ifName, in_bps: null, out_bps: null };\n  \n  if (item.key_.includes('ifHCInOctets')) {\n    ifaces[ifName].in_bps = Math.round(parseFloat(item.lastvalue) * 8);\n  } else if (item.key_.includes('ifHCOutOctets')) {\n    ifaces[ifName].out_bps = Math.round(parseFloat(item.lastvalue) * 8);\n  }\n}\n\n// Sort: main interfaces first, then VLANs\nconst sorted = Object.values(ifaces).sort((a, b) => {\n  const aVlan = a.name.includes('.');\n  const bVlan = b.name.includes('.');\n  if (aVlan !== bVlan) return aVlan ? 1 : -1;\n  return a.name.localeCompare(b.name, undefined, {numeric: true});\n});\n\n// Add status based on traffic\nfor (const iface of sorted) {\n  const hasTraffic = (iface.in_bps && iface.in_bps > 0) || (iface.out_bps && iface.out_bps > 0);\n  iface.status = hasTraffic ? 'up' : 'down';\n}\n\nreturn [{ json: { interfaces: sorted } }];"
      },
