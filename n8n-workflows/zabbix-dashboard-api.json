    {
      "parameters": {
        "jsCode": "const hosts = $input.first().json.result || [];\nlet available = 0, unavailable = 0, unknown = 0;\nconst groups = {};\nfor (const h of hosts) {\n  const avail = h.interfaces?.[0]?.available;\n  if (avail === '1') available++;\n  else if (avail === '2') unavailable++;\n  else unknown++;\n  for (const g of (h.groups || [])) {\n    if (!groups[g.name]) groups[g.name] = { total: 0, up: 0, down: 0 };\n    groups[g.name].total++;\n    if (avail === '1') groups[g.name].up++;\n    else if (avail === '2') groups[g.name].down++;\n  }\n}\nconst groupList = Object.entries(groups).map(([name, data]) => ({ name, ...data })).sort((a, b) => b.total - a.total);\nreturn [{ json: { total: hosts.length, available, unavailable, unknown, groups: groupList } }];"
      },
