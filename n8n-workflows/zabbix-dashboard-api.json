    {
      "parameters": {
        "jsCode": "const items = $json.result || [];\n\nconst vals = {};\nfor (const item of items) {\n  vals[item.key_] = item.lastvalue;\n}\n\nconst cpuUser = parseFloat(vals['synoSystem.ssCpuUser'] || '0');\nconst cpuSystem = parseFloat(vals['synoSystem.ssCpuSystem'] || '0');\nconst cpuUsage = Math.round((cpuUser + cpuSystem) * 10) / 10;\nconst memTotal = parseFloat(vals['ucdavis.memory.memTotalReal'] || '0');\nconst memAvail = parseFloat(vals['ucdavis.memory.memAvailReal'] || '0');\nconst memPct = memTotal > 0 ? Math.round((1 - memAvail / memTotal) * 1000) / 10 : null;\n\nreturn [{ json: {\n  name: 'Synology RT6600ax',\n  ip: '192.168.0.1',\n  status: '1',\n  model: vals['synoSystem.modelName'] || '',\n  firmware: vals['synoSystem.version'] || '',\n  cpu: cpuUsage,\n  memory: memPct,\n  mem_total: memTotal,\n  mem_available: memAvail,\n  temperature: parseFloat(vals['synoSystem.temperature'] || '0'),\n  load1: parseFloat(vals['synoSystem.laLoadInt.1'] || '0'),\n  load5: parseFloat(vals['synoSystem.laLoadInt.2'] || '0'),\n  load15: parseFloat(vals['synoSystem.laLoadInt.3'] || '0'),\n  connections: null,\n  uptime: null\n} }];"
