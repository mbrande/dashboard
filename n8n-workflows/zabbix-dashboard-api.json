      "id": "zdt-hosts",
      "name": "ZDT Get Hosts",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        448,
        1856
      ]
    },
    {
      "parameters": {
        "jsCode": "const hosts = $json.result || [];\nconst token = $('ZDT Auth').item.json.result;\n\nconst body = JSON.stringify({\n  jsonrpc: '2.0',\n  method: 'item.get',\n  params: {\n    groupids: ['2','25','23','24'],\n    output: ['itemid','hostid','name','key_','lastvalue'],\n    search: { key_: 'net.if.' },\n    filter: { status: '0' },\n    limit: 500\n  },\n  auth: token,\n  id: 3\n});\n\nreturn [{json: {hosts, body}}];"
      },
      "id": "zdt-prep",
      "name": "ZDT Prep",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        1856
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://netmon.home.arpa/zabbix/api_jsonrpc.php",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json.body }}",
        "options": {}
      },
      "id": "zdt-items",
      "name": "ZDT Get Items",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        896,
        1856
      ]
    },
    {
      "parameters": {
        "jsCode": "const hosts = $('ZDT Prep').first().json.hosts || [];\nconst items = $json.result || [];\n\nconst hostMap = {};\nfor (const h of hosts) {\n  hostMap[h.hostid] = {\n    hostid: h.hostid,\n    name: h.name,\n    ip: h.interfaces?.[0]?.ip || '',\n    in_bps: 0,\n    out_bps: 0,\n    interface: ''\n  };\n}\n\n// For each host, pick the primary interface (first non-tailscale net.if.in/out without subkey)\nfor (const item of items) {\n  const h = hostMap[item.hostid];\n  if (!h) continue;\n  \n  // Match net.if.in[\"iface\"] or net.if.out[\"iface\"] (no extra subkey like errors/dropped)\n  const inMatch = item.key_.match(/^net\\.if\\.in\\[\"([^\"]+)\"\\]$/);\n  const outMatch = item.key_.match(/^net\\.if\\.out\\[\"([^\"]+)\"\\]$/);\n  \n  if (inMatch) {\n    const iface = inMatch[1];\n    // Skip virtual/tailscale interfaces\n    if (iface.includes('tailscale') || iface.includes('lo')) continue;\n    // Prefer physical interfaces - if we already have one, keep the one with more traffic\n    const val = parseFloat(item.lastvalue) || 0;\n    if (val > h.in_bps || !h.interface) {\n      h.in_bps = val;\n      h.interface = iface;\n    }\n  }\n  if (outMatch) {\n    const iface = outMatch[1];\n    if (iface.includes('tailscale') || iface.includes('lo')) continue;\n    const val = parseFloat(item.lastvalue) || 0;\n    if (val > h.out_bps) {\n      h.out_bps = val;\n    }\n  }\n}\n\n// Filter out hosts with no traffic data and sort by total traffic desc\nconst devices = Object.values(hostMap)\n  .filter(h => h.interface)\n  .sort((a, b) => (b.in_bps + b.out_bps) - (a.in_bps + a.out_bps));\n\nreturn [{ json: { devices } }];"
      },
