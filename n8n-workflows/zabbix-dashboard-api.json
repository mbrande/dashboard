        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({jsonrpc:'2.0',method:'host.get',params:{groupids:['2','25','23','24'],output:['hostid','name'],selectInterfaces:['ip']},auth:$json.result,id:2}) }}",
        "options": {}
